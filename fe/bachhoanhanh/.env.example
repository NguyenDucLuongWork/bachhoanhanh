# Example environment variables for deployment
# Set the base API URL (protocol + host, no trailing slash)
VITE_API_BASE=http://bachhoanhanh

# Keycloak realm used for auth paths
VITE_AUTH_REALM=bachhoanhanh

# Optional: used by Vite server proxy during dev (fallback to VITE_API_BASE)
BACKEND_URL=http://bachhoanhanh
