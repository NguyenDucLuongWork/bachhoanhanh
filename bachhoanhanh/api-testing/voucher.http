### Login to get Access Token
POST http://bachhoanhanh/auth/realms/bachhoanhanh/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=password&
client_id=gateway-client&
username=admin&
password=123456

> {%
    client.global.set("auth_token", response.body.access_token);
%}

### Get All Vouchers
GET http://bachhoanhanh/vouchers
Accept: application/json

### Get Voucher By Id
GET http://bachhoanhanh/vouchers/1
Accept: application/json

### Get Voucher By Code
GET http://bachhoanhanh/vouchers/code/WELCOME10
Accept: application/json

### Create Voucher - Global (no target)
POST http://bachhoanhanh/vouchers
Authorization: Bearer {{auth_token}}
Content-Type: application/json
Accept: application/json

{
  "code": "SUMMER15",
  "description": "15% off all orders this summer",
  "discountType": "PERCENT",
  "discountValue": 15,
  "minOrderValue": 50000,
  "maxDiscountAmount": 75000,
  "usageLimit": 100,
  "startDate": "2026-06-01T00:00:00",
  "endDate": "2026-08-31T23:59:59",
  "active": true,
  "targetProductId": null,
  "targetCatalogId": null
}

### Create Voucher - Target a specific product (productId = 1)
POST http://bachhoanhanh/vouchers
Authorization: Bearer {{auth_token}}
Content-Type: application/json
Accept: application/json

{
  "code": "PORK10",
  "description": "10% off Ba roi heo VietGAP",
  "discountType": "PERCENT",
  "discountValue": 10,
  "minOrderValue": 50000,
  "maxDiscountAmount": 20000,
  "usageLimit": 50,
  "startDate": "2026-01-01T00:00:00",
  "endDate": "2026-12-31T23:59:59",
  "active": true,
  "targetProductId": 1,
  "targetCatalogId": null
}

### Create Voucher - Target a catalog (fresh vegetables)
POST http://bachhoanhanh/vouchers
Authorization: Bearer {{auth_token}}
Content-Type: application/json
Accept: application/json

{
  "code": "VEGFRESH",
  "description": "5000 VND off fresh vegetables",
  "discountType": "FIXED",
  "discountValue": 5000,
  "minOrderValue": 20000,
  "maxDiscountAmount": 0,
  "usageLimit": 0,
  "startDate": "2026-01-01T00:00:00",
  "endDate": "2026-12-31T23:59:59",
  "active": true,
  "targetProductId": null,
  "targetCatalogId": "fresh-food-vegetables"
}

### Update Voucher
PUT http://bachhoanhanh/vouchers/1
Authorization: Bearer {{auth_token}}
Content-Type: application/json
Accept: application/json

{
  "code": "WELCOME10",
  "description": "10% off - updated max discount",
  "discountType": "PERCENT",
  "discountValue": 10,
  "minOrderValue": 0,
  "maxDiscountAmount": 60000,
  "usageLimit": 100,
  "startDate": "2025-01-01T00:00:00",
  "endDate": "2099-12-31T23:59:59",
  "active": true,
  "targetProductId": null,
  "targetCatalogId": null
}

### Delete Voucher
DELETE http://bachhoanhanh/vouchers/2
Authorization: Bearer {{auth_token}}
Accept: application/json

### Apply Voucher - Global voucher
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "WELCOME10",
  "orderTotal": 200000,
  "productIds": [1, 2, 3],
  "catalogIds": ["fresh-food-vegetables", "meat-seafood-pork"]
}

### Apply Voucher - Product-targeted (matching product present)
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "PORK500",
  "orderTotal": 150000,
  "productIds": [1, 4],
  "catalogIds": ["meat-seafood-pork", "snacks-chips"]
}

### Apply Voucher - Product-targeted (product NOT in order, expect 400)
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "PORK500",
  "orderTotal": 150000,
  "productIds": [4, 5],
  "catalogIds": ["snacks-chips", "beverages-soft-drinks"]
}

### Apply Voucher - Catalog-targeted (matching catalog present)
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "VEGGIE5K",
  "orderTotal": 80000,
  "productIds": [2],
  "catalogIds": ["fresh-food-vegetables"]
}

### Apply Voucher - Below min order value (expect 400)
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "FLAT20K",
  "orderTotal": 50000,
  "productIds": [1],
  "catalogIds": ["meat-seafood-pork"]
}

### Apply Voucher - Expired code (expect 400)
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "EXPIRED",
  "orderTotal": 200000,
  "productIds": [1],
  "catalogIds": ["meat-seafood-pork"]
}

### Apply Voucher - Non-existent code (expect 404)
POST http://bachhoanhanh/vouchers/apply
Content-Type: application/json
Accept: application/json

{
  "code": "DOESNOTEXIST",
  "orderTotal": 200000,
  "productIds": [1],
  "catalogIds": ["meat-seafood-pork"]
}

### Confirm Usage (called after order is placed)
POST http://bachhoanhanh/vouchers/confirm-usage/WELCOME10
Authorization: Bearer {{auth_token}}
Accept: application/json
